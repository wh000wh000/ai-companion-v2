{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "corepack pnpm --filter=@proj-airi/stage-web run build",
  "installCommand": "corepack enable && corepack pnpm install --frozen-lockfile",
  "outputDirectory": "apps/stage-web/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://server-production-9b32.up.railway.app/api/:path*" },
    { "source": "/health", "destination": "https://server-production-9b32.up.railway.app/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
