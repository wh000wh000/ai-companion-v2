# ---- Vercel 前端部署环境变量 ----

# 后端服务器 URL（Railway 部署后的地址）
# 留空 = 使用 Vercel rewrites 同域代理（推荐）
# 填写 = 直连后端（需要后端配置 CORS）
VITE_SERVER_URL=

# WebSocket 推送 URL（Vercel 不支持 WS 代理，需直连后端）
# 如 wss://server-production-9b32.up.railway.app/ws/push
# 留空时从 VITE_SERVER_URL 推断
VITE_WS_URL=

# OpenRouter API（前端直连 LLM 时使用）
VITE_OPENROUTER_API_KEY=sk-or-v1-xxx
VITE_OPENROUTER_MODEL=anthropic/claude-sonnet-4

# S3 大文件外置（可选，用于 WASM/TTF/VRM 等大文件上传到 CDN）
# 不配置则大文件随 Vercel 部署（注意 Vercel 限制 100MB）
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# WARP_DRIVE_PUBLIC_BASE=
# STAGE_WEB_WARP_DRIVE_PREFIX=proj-airi/stage-web/main/
