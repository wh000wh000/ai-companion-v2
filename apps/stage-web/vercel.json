{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && corepack pnpm build --filter=@proj-airi/stage-web",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && corepack enable && corepack pnpm install --frozen-lockfile",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://RAILWAY_URL/api/:path*" },
    { "source": "/health", "destination": "https://RAILWAY_URL/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
