# ─── 必需 ───────────────────────────────────────────────────────────────────
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://user:password@localhost:5432/ai_companion

# ─── 服务器 ──────────────────────────────────────────────────────────────────
# 监听端口（默认 3002）
PORT=3002
# 服务器公网 URL（用于 OAuth 回调等）
API_SERVER_URL=http://localhost:3002

# ─── OAuth 认证（可选 — 未配置时对应提供者不可用） ─────────────────────────
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# ─── OpenClaw Agent（可选 — 未配置时使用 fallback LLM） ──────────────────
# WebSocket Gateway URL（如 ws://192.168.3.196:3000）
OPENCLAW_URL=
# Gateway Token（设备配对后获取）
OPENCLAW_TOKEN=
# 降级重试间隔毫秒（默认 300000 = 5分钟）
OPENCLAW_RETRY_INTERVAL_MS=300000

# ─── OpenRouter LLM Fallback（可选 — OpenClaw 不可用时的降级通道） ───────
OPENROUTER_API_KEY=
# API Base URL（默认 https://openrouter.ai/api/v1）
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# 默认模型（默认 anthropic/claude-sonnet-4）
OPENROUTER_MODEL=anthropic/claude-sonnet-4
# 最大 token 数（默认 1024）
OPENROUTER_MAX_TOKENS=1024

# ─── TTS 语音合成（可选 — 未配置时使用 Mock 模式） ─────────────────────────
# 阿里云 DashScope CosyVoice V2 API Key
COSYVOICE_API_KEY=
# CosyVoice API URL（默认使用阿里云 DashScope 端点）
COSYVOICE_API_URL=

# ─── 支付（可选） ────────────────────────────────────────────────────────────
# 启用 Mock 支付（生产环境默认 false，设为 true 启用 Demo 支付流程）
ENABLE_MOCK_PAY=false

# ─── 微信支付（Skeleton，长期计划） ────────────────────────────────────────
# 微信公众号/小程序 AppID
WECHAT_APP_ID=
# 微信支付商户号
WECHAT_MCH_ID=
# 微信支付 APIv3 密钥（32位）
WECHAT_API_KEY=
# 支付结果回调 URL（需 HTTPS）
WECHAT_NOTIFY_URL=

# ─── 支付宝支付（Skeleton，长期计划） ──────────────────────────────────────
# 支付宝应用 AppID
ALIPAY_APP_ID=
# 应用私钥（RSA2 PKCS8 格式，或文件路径）
ALIPAY_PRIVATE_KEY=
# 支付宝公钥（用于回调验签）
ALIPAY_PUBLIC_KEY=
# 异步通知 URL（需 HTTPS）
ALIPAY_NOTIFY_URL=

# ─── 角色（可选） ────────────────────────────────────────────────────────────
# 默认角色 ID（fallback 用，默认 preset-xiaoxing）
DEFAULT_CHARACTER_ID=preset-xiaoxing
